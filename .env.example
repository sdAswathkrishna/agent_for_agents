# ── Required ──────────────────────────────────────────────────────────────────
LYZR_API_KEY=<YOUR_LYZR_API_KEY>
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# ── Optional: LLM Provider Override ──────────────────────────────────────────
# Default provider is gpt-4o. Override here if needed.
# LLM_PROVIDER=claude-3-5-sonnet
# LLM_TEMPERATURE=0.7

# ── Storage (local paths) ─────────────────────────────────────────────────────
ARTIFACTS_DIR=./artifacts
DB_PATH=./agent_for_agents.db

# ── Diagram Tool ──────────────────────────────────────────────────────────────
# "local"      — Python diagrams library (requires: pip install diagrams + graphviz system pkg)
# "mcp"        — AWS Diagrams MCP server via uvx (requires: uvx + awslabs.aws-diagrams-mcp-server)
# Default "local" falls back to matplotlib (no system deps) then a text stub.
DIAGRAM_TOOL_MODE=local

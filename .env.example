# ── Required ──────────────────────────────────────────────────────────────────
LYZR_API_KEY=<YOUR_LYZR_API_KEY>
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# ── Optional: LLM Provider Override ──────────────────────────────────────────
# Default provider is gpt-4o. Override here if needed.
# LLM_PROVIDER=claude-3-5-sonnet
# LLM_TEMPERATURE=0.7

# ── Storage (local paths) ─────────────────────────────────────────────────────
ARTIFACTS_DIR=./artifacts
DB_PATH=./agent_for_agents.db

# ── MCP Diagram Tool ──────────────────────────────────────────────────────────
# Set to "mcp" to attempt external MCP server, "local" to use Python diagrams lib
DIAGRAM_TOOL_MODE=mcp
# MCP server command (default: uvx awslabs.aws-diagrams-mcp-server@latest)
# MCP_DIAGRAM_SERVER_CMD=uvx
# MCP_DIAGRAM_SERVER_ARGS=awslabs.aws-diagrams-mcp-server@latest
